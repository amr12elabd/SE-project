PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/popeyez
JWT_SECRET=your_strong_random_secret_here
JWT_EXPIRES_IN=7d
NODE_ENV=production
CLIENT_URL=https://your-frontend-domain.vercel.app

# AI Assistant (optional — leave blank to use template-based suggestions instead)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email (optional — leave blank to log emails to console instead of sending)
# Supports any SMTP provider: Gmail, SendGrid, Mailgun, etc.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
